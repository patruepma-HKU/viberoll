# Anthropic — генерация сценариев
ANTHROPIC_API_KEY=sk-ant-xxx
SCRIPT_MODEL=claude-haiku-4-5

# HeyGen — говорящая голова (опционально). Без ключа работает MOCK-пайплайн.
HEYGEN_API_KEY=
VIDEO_PROVIDER=mock        # mock | heygen

# Базовый публичный URL (для ссылок на готовые файлы)
PUBLIC_BASE_URL=http://localhost:3000

# Cloudflare R2 (опционально). Если заданы ВСЕ переменные — готовые видео
# заливаются в R2 и отдаются по публичной ссылке. Иначе — локальная раздача.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Публичный домен бакета: либо r2.dev-домен, либо свой кастомный домен.
R2_PUBLIC_BASE_URL=

# Redis (опционально). Если задан REDIS_URL — реестр задач хранится в Redis
# (переживает рестарт, общий для всех инстансов). Иначе — in-memory (1 процесс).
REDIS_URL=
JOB_TTL_SECONDS=3600
